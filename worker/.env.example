# Copy to worker/.env and fill in. worker/.env is gitignored.
SHOPIFY_STORE_DOMAIN=nordic-engros.myshopify.com
SHOPIFY_API_VERSION=2024-10

# Auth via client_credentials grant (token-reveal deprecated 2026-01-01).
# The worker POSTs these to /admin/oauth/access_token to obtain a 24h token.
SHOPIFY_CLIENT_ID=
SHOPIFY_CLIENT_SECRET=

# Origin-country metafield (English country name, e.g. "Poland")
ORIGIN_METAFIELD_NAMESPACE=custom
ORIGIN_METAFIELD_KEY=country_name

# Collections excluded as categories (case-insensitive title/handle match)
EXCLUDE_COLLECTIONS=tilbud,siste-ankomst

# CTA destination printed on the catalogue
CTA_URL=https://www.nordicengros.com/collections/siste-ankomst

# New-product window in days
NEW_WINDOW_DAYS=7
